{
  "name": "photos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "check": "tsc --noEmit",
    "check:all": "npm run check && npm run knip && npm run lint && npm run format",
    "test": "npx playwright test",
    "build:static": "cross-env NEXT_OUTPUT=export next build",
    "deploy:static": "npm run build:static",
    "sync:photos": "node scripts/sync-photos.js",
    "optimize:web": "node scripts/optimize-web-images.js",
    "optimize:web:dry": "cross-env DRY_RUN=1 node scripts/optimize-web-images.js",
    "optimize:web:force": "cross-env FORCE=1 node scripts/optimize-web-images.js",
    "optimize:docker:build": "docker build -f scripts/Dockerfile.optimize -t photos-optimizer .",
    "optimize:docker": "docker run --rm -v %cd%/scripts/.env:/app/scripts/.env photos-optimizer",
    "optimize:docker:dry": "docker run --rm -v %cd%/scripts/.env:/app/scripts/.env -e DRY_RUN=1 photos-optimizer"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.958.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.7",
    "@react-spring/web": "^9.7.5",
    "@types/three": "^0.164.0",
    "classnames": "^2.5.1",
    "cobe": "^0.6.5",
    "d3-geo": "^3.1.1",
    "exiftool-vendored": "^36.0.0",
    "framer-motion": "^12.25.0",
    "next": "^14.2.32",
    "prettier": "^3.2.5",
    "react": "^18",
    "react-dom": "^18",
    "react-globe.gl": "^2.36.0",
    "sharp": "^0.34.5",
    "tailwind-scrollbar": "^3.1.0",
    "three": "^0.180.0",
    "three-geojson-geometry": "^1.3.2",
    "topojson-client": "^3.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "cross-env": "^7.0.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "postcss": "^8",
    "postcss-load-config": "^6.0.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "glob": "10.5.0",
    "minimatch": "^10.0.3"
  }
}
